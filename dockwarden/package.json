{
  "name": "dockwarden",
  "version": "1.0.0",
  "description": "A cross-platform Bitwarden companion app with tags, auto-type, smart views, expiry reminders, and automated backups",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:dev": "concurrently \"npm run watch\" \"wait-on dist/dockwarden/browser/index.html && cross-env ELECTRON_ENV=development electron .\"",
    "electron:build": "npm run build:prod && electron-builder",
    "electron": "electron ."
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "better-sqlite3": "^12.10.0",
    "electron": "^42.3.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.3.0",
    "node-cron": "^4.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.dockwarden.app",
    "productName": "DockWarden",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/dockwarden/browser/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "JaredScar",
      "repo": "DockWarden"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "category": "Utility",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  }
}
